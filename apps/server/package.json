{
  "name": "@repo/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "dev": "portless server bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun --format=esm --minify --sourcemap",
    "check-types": "tsc --noEmit && effect-language-service diagnostics --project tsconfig.json",
    "test": "bun --bun run vitest"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.60",
    "@effect/sql-sqlite-bun": "4.0.0-beta.60",
    "@repo/auth-api": "workspace:*",
    "@repo/spec-api": "workspace:*",
    "effect": "4.0.0-beta.60"
  },
  "devDependencies": {
    "@effect/language-service": "0.86.1",
    "@effect/vitest": "4.0.0-beta.60",
    "@repo/tsconfig": "workspace:*",
    "bun-types": "1.3.13",
    "portless": "0.12.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
