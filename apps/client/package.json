{
  "name": "voel",
  "version": "0.0.0-mvp",
  "main": "expo-router/entry",
  "scripts": {
    "android": "RELEASE_CHANNEL=development expo run:android",
    "android:preview": "RELEASE_CHANNEL=preview expo run:android",
    "android:release": "RELEASE_CHANNEL=release expo run:android",
    "export": "RELEASE_CHANNEL=development eoas publish --branch development --platform all --outputDir ./dist/eoas/development --nonInteractive",
    "export:preview": "RELEASE_CHANNEL=preview eoas publish --branch preview --platform all --outputDir ./dist/eoas/preview --nonInteractive",
    "export:release": "RELEASE_CHANNEL=release eoas publish --branch release --platform all --outputDir ./dist/eoas/release --nonInteractive",
    "fingerprint:android": "RELEASE_CHANNEL=development expo-updates fingerprint:generate --platform android | jq -r .hash",
    "fingerprint:android:preview": "RELEASE_CHANNEL=preview expo-updates fingerprint:generate --platform android | jq -r .hash",
    "fingerprint:android:release": "RELEASE_CHANNEL=release expo-updates fingerprint:generate --platform android | jq -r .hash",
    "fingerprint:ios": "RELEASE_CHANNEL=development expo-updates fingerprint:generate --platform ios | jq -r .hash",
    "fingerprint:ios:preview": "RELEASE_CHANNEL=preview expo-updates fingerprint:generate --platform ios | jq -r .hash",
    "fingerprint:ios:release": "RELEASE_CHANNEL=release expo-updates fingerprint:generate --platform ios | jq -r .hash",
    "ios": "RELEASE_CHANNEL=development expo run:ios",
    "ios:preview": "RELEASE_CHANNEL=preview expo run:ios",
    "ios:release": "RELEASE_CHANNEL=release expo run:ios",
    "runtimeversion:android": "RELEASE_CHANNEL=development expo-updates runtimeversion:resolve --platform android | jq -r .runtimeVersion",
    "runtimeversion:android:preview": "RELEASE_CHANNEL=preview expo-updates runtimeversion:resolve --platform android | jq -r .runtimeVersion",
    "runtimeversion:android:release": "RELEASE_CHANNEL=release expo-updates runtimeversion:resolve --platform android | jq -r .runtimeVersion",
    "runtimeversion:ios": "RELEASE_CHANNEL=development expo-updates runtimeversion:resolve --platform ios | jq -r .runtimeVersion",
    "runtimeversion:ios:preview": "RELEASE_CHANNEL=preview expo-updates runtimeversion:resolve --platform ios | jq -r .runtimeVersion",
    "runtimeversion:ios:release": "RELEASE_CHANNEL=release expo-updates runtimeversion:resolve --platform ios | jq -r .runtimeVersion",
    "start": "RELEASE_CHANNEL=development expo start",
    "start:preview": "RELEASE_CHANNEL=preview expo start",
    "start:release": "RELEASE_CHANNEL=release expo start",
    "prebuild": "RELEASE_CHANNEL=development expo prebuild",
    "prebuild:preview": "RELEASE_CHANNEL=preview expo prebuild",
    "prebuild:release": "RELEASE_CHANNEL=release expo prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "op-sqlite": {
    "fts5": true
  },
  "dependencies": {
