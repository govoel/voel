{
  "name": "voel",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "imports": {
    "#src/*": "./src/*",
    "#assets/*": "./assets/*"
  },
  "scripts": {
    "dev": "portless server bun run --watch src/index.ts",
    "check-types": "tsc --noEmit && effect-language-service diagnostics --project tsconfig.json",
    "android:dev": "RELEASE_CHANNEL=dev expo run:android",
    "android:preview": "RELEASE_CHANNEL=preview expo run:android",
    "android:prod": "RELEASE_CHANNEL=prod expo run:android",
    "ios:dev": "RELEASE_CHANNEL=dev expo run:ios",
    "ios:preview": "RELEASE_CHANNEL=preview expo run:ios",
    "ios:prod": "RELEASE_CHANNEL=prod expo run:ios"
  },
  "dependencies": {
    "@expo/ui": "~56.0.8",
    "@repo/spec-api": "workspace:*",
    "effect": "4.0.0-beta.66",
    "expo": "~56.0.0-preview.12",
    "expo-build-properties": "~56.0.9",
    "expo-constants": "~56.0.11",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.4",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.4",
    "expo-linking": "~56.0.8",
    "expo-router": "~56.2.1",
    "expo-splash-screen": "~56.0.7",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.4",
    "expo-web-browser": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@effect/language-service": "0.86.1",
    "@repo/tsconfig": "workspace:*",
    "@types/react": "~19.2.2",
    "bun-types": "1.3.14",
    "typescript": "~6.0.3"
  }
}
