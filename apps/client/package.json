{
  "name": "voel",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "portless server bun run --watch src/index.ts",
    "check-types": "expo customize tsconfig.json && tsc --noEmit && effect-language-service diagnostics --project tsconfig.json",
    "test": "vitest",
    "test:harness": "bun run harness:all",
    "test-server": "bun run src/services/testing/server-controller/server.ts",
    "harness:with-server": "bun run scripts/harness-with-server.ts",
    "harness:ios": "bun run harness:with-server -- --harnessRunner ios",
    "harness:android": "bun run harness:with-server -- --harnessRunner android",
    "harness:all": "bun run harness:with-server -- --harnessRunner ios --harnessRunner android",
    "android:dev": "RELEASE_CHANNEL=dev expo run:android",
    "android:preview": "RELEASE_CHANNEL=preview expo run:android",
    "android:prod": "RELEASE_CHANNEL=prod expo run:android",
    "ios:dev": "RELEASE_CHANNEL=dev expo run:ios",
    "ios:preview": "RELEASE_CHANNEL=preview expo run:ios",
    "ios:prod": "RELEASE_CHANNEL=prod expo run:ios"
  },
  "dependencies": {
    "@babel/runtime": "7.29.7",
    "@better-auth/expo": "1.6.23",
    "@effect/atom-react": "4.0.0-beta.93",
    "@expo-google-fonts/google-sans": "0.4.0",
    "@expo/material-symbols": "0.1.1",
    "@expo/ui": "~57.0.3",
    "@op-engineering/op-sqlite": "17.1.1",
    "@repo/auth-api": "workspace:*",
    "@repo/effect-kysely": "workspace:*",
    "@repo/spec-api": "workspace:*",
    "@tanstack/react-form": "1.33.0",
    "better-auth": "1.6.23",
    "effect": "4.0.0-beta.93",
    "expo": "^57.0.2",
    "expo-build-properties": "~57.0.3",
    "expo-constants": "~57.0.3",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-network": "~57.0.0",
    "expo-plugin-ios-static-libraries": "1.1.0",
    "expo-router": "~57.0.3",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "metro": "^0.84.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.2",
    "react-native-xxhash": "0.1.10"
  },
  "devDependencies": {
    "@effect/language-service": "0.86.4",
    "@effect/platform-bun": "4.0.0-beta.93",
    "@effect/vitest": "4.0.0-beta.93",
    "@react-native-harness/platform-android": "1.3.0",
    "@react-native-harness/platform-apple": "1.3.0",
    "@repo/effect-react-native-harness": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@srsholmes/vitest-react-native": "0.1.5",
    "@testing-library/react-native": "14.0.1",
    "@types/react": "~19.2.2",
    "@vitejs/plugin-react": "6.0.3",
    "agent-device": "0.18.3",
    "bun-types": "1.3.14",
    "react-native-harness": "1.3.0",
    "test-renderer": "1.2.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
