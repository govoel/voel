{
  "extends": ["expo/tsconfig.base", "@repo/tsconfig/effect.json"],
  "compilerOptions": {
    "strict": true,
    "paths": {
      "#src/*": ["./src/*"],
      "#assets/*": ["./assets/*"],
      "#modules/*": ["./modules/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
