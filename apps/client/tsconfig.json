{
  "extends": ["expo/tsconfig.base"],
  "compilerOptions": {
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["*"],
      "@/*": ["node_modules/@voel/server/src/*"]
    },
    "types": ["bun-types"]
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts", "nativewind-env.d.ts"]
}
