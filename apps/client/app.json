{
  "expo": {
    "name": "Voel",
    "slug": "voel",
    "version": "0.0.0-alpha",
    "scheme": "voel",
    "newArchEnabled": true,
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.svg"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Inter-Bold.otf",
            "./assets/fonts/Inter-Thin.otf",
            "./assets/fonts/Inter-Black.otf",
            "./assets/fonts/Inter-Light.otf",
            "./assets/fonts/Inter-Italic.otf",
            "./assets/fonts/Inter-Medium.otf",
            "./assets/fonts/Inter-Regular.otf",
            "./assets/fonts/Inter-SemiBold.otf",
            "./assets/fonts/Inter-ExtraBold.otf",
            "./assets/fonts/Inter-BoldItalic.otf",
            "./assets/fonts/Inter-ExtraLight.otf",
            "./assets/fonts/Inter-ThinItalic.otf",
            "./assets/fonts/Inter-BlackItalic.otf",
            "./assets/fonts/Inter-LightItalic.otf",
            "./assets/fonts/Inter-MediumItalic.otf",
            "./assets/fonts/Inter-SemiBoldItalic.otf",
            "./assets/fonts/Inter-ExtraBoldItalic.otf",
            "./assets/fonts/Inter-ExtraLightItalic.otf"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/icons/splash-icon-dark.png",
          "dark": {
            "image": "./assets/icons/splash-icon-light.png",
            "backgroundColor": "#000000"
          },
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.voel",
      "icon": {
        "dark": "./assets/icons/ios-dark.png",
        "light": "./assets/icons/ios-light.png",
        "tinted": "./assets/icons/ios-tinted.png"
      }
    },
    "android": {
      "package": "app.voel",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon-bigger.png",
        "monochromeImage": "./assets/icons/adaptive-icon-bigger.png",
        "backgroundColor": "#ffffff"
      }
    }
  }
}
