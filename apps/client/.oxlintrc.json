{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "extends": ["../../.oxlintrc.json", "../../.oxlintrc.react.json"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "error",
    "perf": "error",
    "style": "error",
    "restriction": "error",
    "nursery": "error"
  },
  "env": {
    "builtin": true,
    "node": true
  },
  "overrides": [
    {
      "files": ["**/*.{js,jsx,ts,tsx}"],
      "excludeFiles": [
        "**/__tests__/**",
        "**/*.test.{js,jsx,ts,tsx}",
        "**/*.spec.{js,jsx,ts,tsx}",
        "**/*.test.{cjs,cts,mjs,mts}",
        "**/*.spec.{cjs,cts,mjs,mts}"
      ],
      "rules": {
        "voel/no-server-imports-in-client": "error"
      }
    }
  ]
}
