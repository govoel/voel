{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:expoMonorepo",
    "group:eslintMonorepo",
    "helpers:pinGitHubActionDigests"
  ],
  "rangeStrategy": "auto",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "timezone": "America/Chicago",
  "schedule": ["at any time"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "groupName": "better-auth-monorepo",
      "matchPackageNames": ["/better-auth/"]
    }
  ],
  "recreateWhen": "never"
}
