{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:expoMonorepo",
    "group:eslintMonorepo"
  ],
  "rangeStrategy": "pin",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "timezone": "America/Chicago",
  "schedule": ["* 0-5 * * *"],
  "labels": ["deps"],
  "packageRules": [{
    "groupName": "Better Auth monorepo packages",
    "matchSourceUrls": ["https://github.com/better-auth/better-auth"]
  }]
}
