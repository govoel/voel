{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:expoMonorepo",
    "group:eslintMonorepo"
  ],
  "rangeStrategy": "pin",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "timezone": "America/Chicago",
  "schedule": ["* 0-5 * * *"],
  "labels": ["dependencies"],
  "packageRules": [{
    "groupName": "better-auth-monorepo",
    "matchPackageNames": ["/better-auth/"]
  }]
}
