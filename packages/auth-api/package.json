{
  "name": "@repo/auth-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    "./client.ts": "./src/client.ts",
    "./migrations/*": "./src/migrations/*",
    "./server.ts": "./src/server.ts"
  },
  "scripts": {
    "dev": "portless server bun run --watch src/index.ts",
    "check-types": "tsc --noEmit && effect-language-service diagnostics --project tsconfig.json"
  },
  "dependencies": {
    "@better-auth/expo": "1.6.23",
    "@repo/effect-kysely": "workspace:*",
    "better-auth": "1.6.23",
    "effect": "4.0.0-beta.97"
  },
  "devDependencies": {
    "@effect/language-service": "0.86.6",
    "@repo/tsconfig": "workspace:*",
    "bun-types": "1.3.14",
    "portless": "0.15.1",
    "typescript": "6.0.3"
  }
}
