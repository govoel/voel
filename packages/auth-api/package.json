{
  "name": "@repo/auth-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    "./client.ts": "./src/client.ts",
    "./migrations.ts": "./src/migrations.ts",
    "./server.ts": "./src/server.ts"
  },
  "scripts": {
    "dev": "portless server bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun --format=esm --minify --sourcemap",
    "check-types": "tsc --noEmit && effect-language-service diagnostics --project tsconfig.json",
    "test": "bun test --concurrent --only-failures"
  },
  "dependencies": {
    "@better-auth/expo": "1.6.9",
    "@effect/sql-sqlite-bun": "4.0.0-beta.59",
    "better-auth": "1.6.9",
    "effect": "4.0.0-beta.59"
  },
  "devDependencies": {
    "@effect/language-service": "0.85.1",
    "@repo/tsconfig": "workspace:*",
    "bun-types": "1.3.13",
    "portless": "0.11.1",
    "typescript": "6.0.3"
  }
}
