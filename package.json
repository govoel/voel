{
  "name": "voel",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "oxlint . --ignore-pattern .repos/** --type-aware --type-check --deny-warnings",
    "lint:fix": "oxlint . --ignore-pattern .repos/** --fix --type-aware --type-check --deny-warnings",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "build": "turbo run build",
    "clean": "find . \\( -type d -name node_modules -o -type d -name .turbo \\) -prune -exec rm -rf -- {} \\;",
    "changeset": "changeset",
    "release:version": "changeset version",
    "release:tag": "changeset tag"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "eslint-plugin-turbo": "2.10.3",
    "opensrc": "0.7.3",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "oxlint-tsgolint": "0.24.0",
    "turbo": "2.10.3",
    "typescript": "6.0.3"
  },
  "engines": {
    "bun": "1.3.14"
  },
  "packageManager": "bun@1.3.14",
  "patchedDependencies": {
    "@react-native-harness/jest@1.3.0": "patches/@react-native-harness%2Fjest@1.3.0.patch",
    "@react-native-harness/babel-preset@1.3.0": "patches/@react-native-harness%2Fbabel-preset@1.3.0.patch",
    "@react-native-harness/bundler-metro@1.3.0": "patches/@react-native-harness%2Fbundler-metro@1.3.0.patch",
    "@react-native-harness/runtime@1.3.0": "patches/@react-native-harness%2Fruntime@1.3.0.patch"
  }
}
