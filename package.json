{
  "name": "voel",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "oxlint --ignore-pattern .repos/** --type-aware --type-check --deny-warnings",
    "lint:fix": "oxlint --ignore-pattern .repos/** --fix --type-aware --type-check --deny-warnings",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "build": "turbo run build",
    "clean": "find . \\( -type d -name node_modules -o -type d -name .turbo \\) -prune -exec rm -rf -- {} \\;",
    "changeset": "changeset",
    "release:version": "changeset version",
    "release:tag": "changeset tag"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "eslint-plugin-turbo": "2.9.14",
    "oxfmt": "0.50.0",
    "oxlint": "1.65.0",
    "oxlint-tsgolint": "0.22.1",
    "turbo": "2.9.14",
    "typescript": "6.0.3"
  },
  "engines": {
    "bun": "1.3.14"
  },
  "packageManager": "bun@1.3.14",
  "patchedDependencies": {
    "effect@4.0.0-beta.66": "patches/effect@4.0.0-beta.66.patch"
  }
}
