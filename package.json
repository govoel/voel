{
  "name": "voel",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "oxlint --type-aware --type-check --deny-warnings",
    "lint:fix": "oxlint --fix --type-aware --type-check --deny-warnings",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "build": "turbo run build",
    "clean": "find . \\( -type d -name node_modules -o -type d -name .turbo \\) -prune -exec rm -rf -- {} \\;",
    "changeset": "changeset",
    "release:version": "changeset version",
    "release:tag": "changeset tag"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.31.0",
    "eslint-plugin-turbo": "2.9.6",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "turbo": "2.9.6",
    "typescript": "6.0.3"
  },
  "engines": {
    "bun": "1.3.13"
  },
  "packageManager": "bun@1.3.13"
}
